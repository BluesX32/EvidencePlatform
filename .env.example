# Copy to .env and fill in values before running locally.

# Database
DATABASE_URL=postgresql+asyncpg://evidence:evidence@localhost:5432/evidenceplatform

# Auth
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_HOURS=24

# Backend
BACKEND_CORS_ORIGINS=http://localhost:5173

# Email verification (leave SMTP_HOST empty to disable sending and log the link instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@evidenceplatform.local
SMTP_FROM_NAME=EvidencePlatform
FRONTEND_BASE_URL=http://localhost:5173
